# Azure AD App Registration credentials
# Get these from portal.azure.com > Azure Active Directory > App registrations
AZURE_TENANT_ID=your-tenant-id-guid
AZURE_CLIENT_ID=your-client-id-guid
AZURE_CLIENT_SECRET=your-client-secret-value

# SharePoint hostname (your tenant's SharePoint domain)
# Example: contoso.sharepoint.com
SP_HOSTNAME=your-tenant.sharepoint.com

# Default SharePoint site path (optional)
# If set, tools will use this site when no site_path is specified
# Example: /sites/ProjectDashboard
# SP_DEFAULT_SITE_PATH=/sites/YourSite

# Server
# Transport mode: "http" for remote/connector use, "stdio" for local Claude Code
# TRANSPORT=http
# PORT=3500
# NODE_ENV=production
